# Route all requests through the Slim front controller (public/ is the
# Apache DocumentRoot).

RewriteEngine On

# Preserve Authorization for PHP/FastCGI environments that do not pass it
# through automatically.
SetEnvIf Authorization "(.+)" HTTP_AUTHORIZATION=$1
RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

# Allow direct access to real files (e.g., static assets).
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d

# Rewrite everything else to index.php, preserving the query string.
RewriteRule ^ index.php [QSA,L]
