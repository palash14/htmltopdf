# =============================================================================
# url-to-pdf-api — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Environment variables always override values in config/config.php.
#
# If you load this file via a library (e.g. vlucas/phpdotenv) make sure to
# call $dotenv->load() before ConfigLoader::load() is invoked.
# On cPanel you can also set these via the "Environment Variables" section in
# the control panel or in the PHP-FPM pool configuration.
# =============================================================================


# -----------------------------------------------------------------------------
# REQUIRED — the application will not start without these
# -----------------------------------------------------------------------------

# TCP port the application listens on (1–65535).
# Behind Apache/Nginx this is typically 80 or 443.
PORT=8080

# Absolute path to the wkhtmltopdf binary.
# Find the path with:  which wkhtmltopdf
WKHTMLTOPDF_PATH=/usr/local/bin/wkhtmltopdf

# Comma-separated list of valid API keys (1–100 keys).
# Clients supply these in:  Authorization: Bearer <key>
# Keep keys long (≥32 chars), random, and secret.
API_KEYS=replace-with-a-long-random-secret-key,optional-second-key

# Absolute path to the directory where PDFs and sidecar JSON files are stored.
# The directory must be writable by the PHP process.
STORAGE_DIR=/var/www/html/storage/pdfs

# Fully-qualified base URL of this API (no trailing slash).
# Used to build the download_url returned in successful responses.
BASE_URL=https://api.example.com


# -----------------------------------------------------------------------------
# OPTIONAL — defaults are applied when these are absent or empty
# -----------------------------------------------------------------------------

# How long (seconds) a generated PDF is kept before it may be deleted.
# Range: 60–86400  |  Default: 3600  (1 hour)
# TTL_SECONDS=3600

# How often (seconds) the cleanup cron job runs.
# Range: 10–3600  |  Default: 60
# CLEANUP_INTERVAL_SECONDS=60

# Maximum number of wkhtmltopdf processes that may run simultaneously.
# Range: 1–50  |  Default: 5
# MAX_CONCURRENT_RENDERERS=5

# Maximum number of seconds to wait for a single wkhtmltopdf render.
# Exceeding this returns HTTP 504.
# Range: 5–300  |  Default: 30
# RENDER_TIMEOUT_SECONDS=30

# Renderer backend. Use "chrome" for closest browser/CSS fidelity.
# Default: wkhtmltopdf
# RENDERER_ENGINE=wkhtmltopdf

# Required when RENDERER_ENGINE=chrome.
# Common paths:
#   /usr/bin/google-chrome
#   /usr/bin/chromium
#   /usr/bin/chromium-browser
# CHROME_PATH=/usr/bin/google-chrome

# Maximum total size of the storage directory in megabytes.
# Once this limit is reached, new conversions return HTTP 507.
# Leave unset (or empty) to disable the limit.
# MAX_STORAGE_MB=

# Per-API-key rate limit in requests per minute.
# Exceeding this returns HTTP 429.
# Leave unset (or empty) to disable rate limiting.
# Range when set: 1–1000
# RATE_LIMIT_RPM=
